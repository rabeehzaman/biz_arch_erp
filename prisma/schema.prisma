  unitCost          Decimal  @db.Decimal(10, 2)
  initialQuantity   Decimal  @db.Decimal(10, 4)
  remainingQuantity Decimal  @db.Decimal(10, 4)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  consumptions          StockLotConsumption[]
  debitNoteConsumptions DebitNoteLotConsumption[]

  @@index([productId, lotDate])
  @@index([productId, remainingQuantity])
  @@index([organizationId])
  @@index([organizationId, lotDate(sort: Desc)])
  @@index([organizationId, productId])
  @@index([warehouseId])
  @@index([purchaseInvoiceId])
  @@map("stock_lots")
}

enum StockSourceType {
  PURCHASE
  OPENING_STOCK
  ADJUSTMENT
  CREDIT_NOTE
  STOCK_TRANSFER
}

enum AdjustmentType {
  INCREASE
  DECREASE
}

enum StockTakeStatus {
  DRAFT
  RECONCILED
}

model StockLotConsumption {
  id             String       @id @default(cuid())
  stockLotId     String
  stockLot       StockLot     @relation(fields: [stockLotId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  invoiceItemId String?
  invoiceItem   InvoiceItem? @relation(fields: [invoiceItemId], references: [id], onDelete: Cascade)

  stockTransferItemId String?
  stockTransferItem   StockTransferItem? @relation(fields: [stockTransferItemId], references: [id], onDelete: Cascade)

  inventoryAdjustmentItemId String?
  inventoryAdjustmentItem   InventoryAdjustmentItem? @relation(fields: [inventoryAdjustmentItemId], references: [id], onDelete: Cascade)

  quantityConsumed Decimal @db.Decimal(10, 4)
  unitCost         Decimal @db.Decimal(10, 2)
  totalCost        Decimal @db.Decimal(12, 2)

  createdAt DateTime @default(now())

  @@index([stockLotId])
  @@index([invoiceItemId])
  @@index([stockTransferItemId])
  @@index([inventoryAdjustmentItemId])
  @@index([organizationId])
  @@map("stock_lot_consumptions")
}

model OpeningStock {
  id             String       @id @default(cuid())
  productId      String
  product        Product      @relation(fields: [productId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  quantity  Decimal  @db.Decimal(10, 4)
  unitCost  Decimal  @db.Decimal(10, 2)
  stockDate DateTime

  notes String?

  warehouseId String?
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stockLot      StockLot?
  mobileDevices MobileDevice[]

  @@index([organizationId])
  @@index([productId])
  @@index([warehouseId])
  @@map("opening_stocks")
}

// ==================== INVENTORY ADJUSTMENTS ====================

model InventoryAdjustment {
  id               String       @id @default(cuid())
  adjustmentNumber String
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id])

  adjustmentDate DateTime
  notes          String?
  status         StockTakeStatus @default(DRAFT)

  warehouseId String?
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])

  reconciledAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  items InventoryAdjustmentItem[]

  @@unique([organizationId, adjustmentNumber])
  @@index([organizationId])
  @@index([organizationId, adjustmentDate(sort: Desc)])
  @@index([organizationId, status])
  @@index([warehouseId])
  @@map("inventory_adjustments")
}

model InventoryAdjustmentItem {
  id                    String              @id @default(cuid())
  inventoryAdjustmentId String
  inventoryAdjustment   InventoryAdjustment @relation(fields: [inventoryAdjustmentId], references: [id], onDelete: Cascade)
  organizationId        String
  organization          Organization        @relation(fields: [organizationId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  systemQuantity   Decimal        @default(0) @db.Decimal(10, 4)
  physicalQuantity Decimal        @default(0) @db.Decimal(10, 4)
  adjustmentType   AdjustmentType
  quantity         Decimal        @db.Decimal(10, 4)
  unitCost         Decimal        @db.Decimal(10, 2)
  reason           String?

  createdAt DateTime @default(now())

  stockLot        StockLot?
  lotConsumptions StockLotConsumption[]

  @@index([inventoryAdjustmentId])
  @@index([productId])
  @@index([organizationId])
  @@map("inventory_adjustment_items")
}

// ==================== COST AUDIT LOG ====================

model CostAuditLog {
  id             String       @id @default(cuid())
  productId      String
  product        Product      @relation(fields: [productId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  invoiceItemId String
  invoiceItem   InvoiceItem @relation(fields: [invoiceItemId], references: [id], onDelete: Cascade)

  oldCOGS      Decimal @db.Decimal(12, 2)
  newCOGS      Decimal @db.Decimal(12, 2)
  changeAmount Decimal @db.Decimal(12, 2)

  changeReason String
  triggeredBy  String?

  changedAt DateTime @default(now())

  @@index([productId, changedAt])
  @@index([invoiceItemId])
  @@index([organizationId])
  @@map("cost_audit_logs")
}

// ==================== CUSTOMER TRANSACTIONS (FOR STATEMENT) ====================

model CustomerTransaction {
  id             String       @id @default(cuid())
  customerId     String
  customer       Customer     @relation(fields: [customerId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  transactionType CustomerTransactionType
  transactionDate DateTime
  amount          Decimal                 @db.Decimal(12, 2)
  description     String

  invoiceId    String?
  paymentId    String?
  creditNoteId String?
  creditNote   CreditNote? @relation(fields: [creditNoteId], references: [id])

  runningBalance Decimal @db.Decimal(12, 2)

  createdAt DateTime @default(now())

  @@index([customerId, transactionDate])
  @@index([organizationId])
  @@index([organizationId, transactionDate(sort: Desc)])
  @@map("customer_transactions")
}

enum CustomerTransactionType {
  OPENING_BALANCE
  INVOICE
  PAYMENT
  CREDIT_NOTE
  ADJUSTMENT
}

// ==================== SUPPLIER TRANSACTIONS (FOR STATEMENT) ====================

model SupplierTransaction {
  id             String       @id @default(cuid())
  supplierId     String
  supplier       Supplier     @relation(fields: [supplierId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  transactionType SupplierTransactionType
  transactionDate DateTime
  amount          Decimal                 @db.Decimal(12, 2)
  description     String

  purchaseInvoiceId String?
  supplierPaymentId String?
  debitNoteId       String?
  debitNote         DebitNote? @relation(fields: [debitNoteId], references: [id])

  runningBalance Decimal @db.Decimal(12, 2)

  createdAt DateTime @default(now())

  @@index([supplierId, transactionDate])
  @@index([organizationId])
  @@index([organizationId, transactionDate(sort: Desc)])
  @@map("supplier_transactions")
}

enum SupplierTransactionType {
  OPENING_BALANCE
  PURCHASE_INVOICE
  PAYMENT
  DEBIT_NOTE
  ADJUSTMENT
}

// ==================== PRODUCT CATEGORIES ====================

model ProductCategory {
  id             String       @id @default(cuid())
  name           String
  slug           String
  color          String?      @default("#6366f1")
  sortOrder      Int          @default(0)
  isActive       Boolean      @default(true)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  products Product[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@map("product_categories")
}

// ==================== POS (POINT OF SALE) ====================

model POSSession {
  id                String           @id @default(cuid())
  sessionNumber     String
  organizationId    String
  organization      Organization     @relation(fields: [organizationId], references: [id])
  userId            String
  user              User             @relation("OpenedSessions", fields: [userId], references: [id])
  closedById        String?
  closedBy          User?            @relation("ClosedSessions", fields: [closedById], references: [id])
  employeeId        String?
  employee          Employee?        @relation(fields: [employeeId], references: [id])
  status            POSSessionStatus @default(OPEN)
  openedAt          DateTime         @default(now())
  closedAt          DateTime?
  openingCash       Decimal          @default(0) @db.Decimal(12, 2)
  closingCash       Decimal?         @db.Decimal(12, 2)
  expectedCash      Decimal?         @db.Decimal(12, 2)
  cashDifference    Decimal?         @db.Decimal(12, 2)
  totalSales              Decimal          @default(0) @db.Decimal(12, 2)
  totalTransactions       Int              @default(0)
  totalReturns            Decimal          @default(0) @db.Decimal(12, 2)
  totalReturnTransactions Int              @default(0)
  notes             String?

  branchId    String?
  branch      Branch?    @relation(fields: [branchId], references: [id])
  warehouseId String?
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoices             Invoice[]
  creditNotes          CreditNote[]
  heldOrders           POSHeldOrder[]
  kotOrders            KOTOrder[]
  restaurantPOSOrders  RestaurantPOSOrder[]

  @@unique([organizationId, sessionNumber])
  @@index([organizationId])
  @@index([organizationId, openedAt(sort: Desc)])
  @@index([organizationId, branchId, warehouseId, status])
  @@index([userId])
  @@index([closedById])
  @@index([warehouseId])
  @@map("pos_sessions")
}

model POSHeldOrder {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  sessionId      String
  session        POSSession   @relation(fields: [sessionId], references: [id])
  customerId     String?
  customer       Customer?    @relation(fields: [customerId], references: [id])
  customerName   String?
  items          Json
  subtotal       Decimal      @db.Decimal(12, 2)
  notes          String?
  heldAt         DateTime     @default(now())

  @@index([organizationId])
  @@index([sessionId])
  @@map("pos_held_orders")
}

// ==================== SETTINGS ====================

model Setting {
  id             String       @id @default(cuid())
  key            String
  value          String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  userId         String?      // null = org-level default, non-null = user-level override
  user           User?        @relation("UserSettings", fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, key, userId])
  @@index([organizationId])
  @@index([userId])
  @@map("settings")
}

// ==================== ACCOUNTING ====================

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum AccountSubType {
  CURRENT_ASSET
  FIXED_ASSET
  BANK
  CASH
  ACCOUNTS_RECEIVABLE
  INVENTORY
  OTHER_ASSET
  CURRENT_LIABILITY
  LONG_TERM_LIABILITY
  ACCOUNTS_PAYABLE
  OTHER_LIABILITY
  OWNERS_EQUITY
  RETAINED_EARNINGS
  OTHER_EQUITY
  SALES_REVENUE
  OTHER_REVENUE
  COST_OF_GOODS_SOLD
  OPERATING_EXPENSE
  PAYROLL_EXPENSE
  OTHER_EXPENSE
}

enum JournalEntryStatus {
  DRAFT
  POSTED
  VOID
}

enum JournalSourceType {
  MANUAL
  INVOICE
  PURCHASE_INVOICE
  PAYMENT
  SUPPLIER_PAYMENT
  EXPENSE
  CREDIT_NOTE
  DEBIT_NOTE
  TRANSFER
  OPENING_BALANCE
  POS_SESSION_CLOSE
  POS_SESSION_OPEN
  KARIGAR_TRANSACTION
  INVENTORY_ADJUSTMENT
}

enum ExpenseStatus {
  DRAFT
  APPROVED
  PAID
  VOID
}

enum CashBankTransactionType {
  DEPOSIT
  WITHDRAWAL
  TRANSFER_IN
  TRANSFER_OUT
  OPENING_BALANCE
  ADJUSTMENT
}

// ==================== CHART OF ACCOUNTS ====================

model Account {
  id             String         @id @default(cuid())
  code           String
  name           String
  accountType    AccountType
  accountSubType AccountSubType
  description    String?
  parentId       String?
  parent         Account?       @relation("AccountTree", fields: [parentId], references: [id])
  children       Account[]      @relation("AccountTree")
  isSystem       Boolean        @default(false)
  isActive       Boolean        @default(true)
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id])
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  journalEntryLines JournalEntryLine[]
  expenseItems      ExpenseItem[]
  cashBankAccount   CashBankAccount?
  paymentAdjustments Payment[] @relation("PaymentAdjustmentAccount")
  supplierPaymentAdjustments SupplierPayment[] @relation("SupplierPaymentAdjustmentAccount")

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([parentId])
  @@map("accounts")
}

// ==================== CASH & BANK ACCOUNTS ====================

model CashBankAccount {
  id             String         @id @default(cuid())
  name           String
  accountId      String         @unique
  account        Account        @relation(fields: [accountId], references: [id])
  accountSubType AccountSubType // BANK or CASH
  bankName       String?
  accountNumber  String?
  balance        Decimal        @default(0) @db.Decimal(12, 2)
  isDefault      Boolean        @default(false)
  isActive       Boolean        @default(true)

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  transactions CashBankTransaction[]
  expenses     Expense[]
  defaultCashRegisterConfigs POSRegisterConfig[] @relation("POSRegisterDefaultCashAccount")
  defaultBankRegisterConfigs POSRegisterConfig[] @relation("POSRegisterDefaultBankAccount")
  orgDefaultCash             Organization[]      @relation("OrgDefaultCashAccount")
  orgDefaultBank             Organization[]      @relation("OrgDefaultBankAccount")
  userAccess                 UserCashBankAccess[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([branchId])
  @@map("cash_bank_accounts")
}

model CashBankTransaction {
  id                String                  @id @default(cuid())
  cashBankAccountId String
  cashBankAccount   CashBankAccount         @relation(fields: [cashBankAccountId], references: [id])
  transactionType   CashBankTransactionType
  amount            Decimal                 @db.Decimal(12, 2)
  runningBalance    Decimal                 @db.Decimal(12, 2)
  description       String
  referenceType     String?
  referenceId       String?
  transactionDate   DateTime
  organizationId    String
  organization      Organization            @relation(fields: [organizationId], references: [id])
  createdById       String?
  createdBy         User?                   @relation("CashBankTransactionCreator", fields: [createdById], references: [id])
  createdAt         DateTime                @default(now())

  @@index([cashBankAccountId, transactionDate])
  @@index([organizationId])
  @@index([organizationId, transactionDate(sort: Desc)])
  @@map("cash_bank_transactions")
}

// ==================== EXPENSES ====================

model Expense {
  id                String           @id @default(cuid())
  expenseNumber     String
  status            ExpenseStatus    @default(DRAFT)
  supplierId        String?
  supplier          Supplier?        @relation(fields: [supplierId], references: [id])
  cashBankAccountId String?
  cashBankAccount   CashBankAccount? @relation(fields: [cashBankAccountId], references: [id])
  expenseDate       DateTime         @default(now())
  description       String?
  subtotal          Decimal          @db.Decimal(12, 2)
  total             Decimal          @db.Decimal(12, 2)

  totalCgst     Decimal @default(0) @db.Decimal(12, 2)
  totalSgst     Decimal @default(0) @db.Decimal(12, 2)
  totalIgst     Decimal @default(0) @db.Decimal(12, 2)
  placeOfSupply String?
  isInterState  Boolean @default(false)

  // Saudi VAT
  totalVat Decimal? @db.Decimal(12, 2)

  notes          String?
  journalEntryId String?
  journalEntry   JournalEntry? @relation(fields: [journalEntryId], references: [id])

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  items ExpenseItem[]

  @@unique([organizationId, expenseNumber])
  @@index([organizationId])
  @@index([organizationId, expenseDate(sort: Desc)])
  @@index([organizationId, status])
  @@index([supplierId])
  @@index([cashBankAccountId])
  @@map("expenses")
}

model ExpenseItem {
  id          String  @id @default(cuid())
  expenseId   String
  expense     Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  accountId   String
  account     Account @relation(fields: [accountId], references: [id])
  description String
  amount      Decimal @db.Decimal(12, 2)

  gstRate    Decimal @default(0) @db.Decimal(5, 2)
  cgstAmount Decimal @default(0) @db.Decimal(12, 2)
  sgstAmount Decimal @default(0) @db.Decimal(12, 2)
  igstAmount Decimal @default(0) @db.Decimal(12, 2)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([expenseId])
  @@index([accountId])
  @@index([organizationId])
  @@map("expense_items")
}

// ==================== JOURNAL ENTRIES ====================

model JournalEntry {
  id            String             @id @default(cuid())
  journalNumber String
  date          DateTime
  description   String
  status        JournalEntryStatus @default(DRAFT)
  sourceType    JournalSourceType  @default(MANUAL)
  sourceId      String?

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  lines    JournalEntryLine[]
  expenses Expense[]

  @@unique([organizationId, journalNumber])
  @@index([organizationId])
  @@index([organizationId, date(sort: Desc)])
  @@index([organizationId, status])
  @@index([sourceType, sourceId])
  @@index([branchId])
  @@map("journal_entries")
}

model JournalEntryLine {
  id             String       @id @default(cuid())
  journalEntryId String
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  accountId      String
  account        Account      @relation(fields: [accountId], references: [id])
  description    String?
  debit          Decimal      @default(0) @db.Decimal(12, 2)
  credit         Decimal      @default(0) @db.Decimal(12, 2)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())

  @@index([journalEntryId])
  @@index([accountId])
  @@index([organizationId])
  @@map("journal_entry_lines")
}

// ==================== BRANCHES & WAREHOUSES ====================

model Branch {
  id             String       @id @default(cuid())
  name           String
  code           String
  address        String?
  city           String?
  state          String?
  phone          String?
  isActive       Boolean      @default(true)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  warehouses         Warehouse[]
  invoices           Invoice[]
  quotations         Quotation[]
  purchaseInvoices   PurchaseInvoice[]
  creditNotes        CreditNote[]
  debitNotes         DebitNote[]
  payments           Payment[]
  supplierPayments   SupplierPayment[]
  posSessions        POSSession[]
  cashBankAccounts   CashBankAccount[]
  journalEntries     JournalEntry[]
  expenses           Expense[]
  stockTransfersFrom StockTransfer[]       @relation("SourceBranch")
  stockTransfersTo   StockTransfer[]       @relation("DestinationBranch")
  userAccess         UserWarehouseAccess[]
  posRegisterConfigs POSRegisterConfig[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@map("branches")
}

model Warehouse {
  id             String       @id @default(cuid())
  name           String
  code           String
  branchId       String
  branch         Branch       @relation(fields: [branchId], references: [id])
  address        String?
  isActive       Boolean      @default(true)
  isDefault      Boolean      @default(false)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  invoices           Invoice[]
  quotations         Quotation[]
  purchaseInvoices   PurchaseInvoice[]
  creditNotes        CreditNote[]
  debitNotes         DebitNote[]
  posSessions        POSSession[]
  stockLots          StockLot[]
  openingStocks      OpeningStock[]
  stockTransfersFrom      StockTransfer[]       @relation("SourceWarehouse")
  stockTransfersTo        StockTransfer[]       @relation("DestinationWarehouse")
  stockTransferItems      StockTransferItem[]
  userAccess              UserWarehouseAccess[]
  posRegisterConfigs      POSRegisterConfig[]
  inventoryAdjustments    InventoryAdjustment[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([branchId])
  @@map("warehouses")
}

model POSRegisterConfig {
  id                   String           @id @default(cuid())
  locationKey          String
  organizationId       String
  organization         Organization     @relation(fields: [organizationId], references: [id])
  branchId             String?
  branch               Branch?          @relation(fields: [branchId], references: [id])
  warehouseId          String?
  warehouse            Warehouse?       @relation(fields: [warehouseId], references: [id])
  defaultCashAccountId String?
  defaultCashAccount   CashBankAccount? @relation("POSRegisterDefaultCashAccount", fields: [defaultCashAccountId], references: [id])
  defaultBankAccountId String?
  defaultBankAccount   CashBankAccount? @relation("POSRegisterDefaultBankAccount", fields: [defaultBankAccountId], references: [id])
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  @@unique([organizationId, locationKey])
  @@index([organizationId])
  @@index([branchId])
  @@index([warehouseId])
  @@map("pos_register_configs")
}

// ==================== STOCK TRANSFERS ====================

model StockTransfer {
  id             String       @id @default(cuid())
  transferNumber String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  sourceBranchId    String
  sourceBranch      Branch    @relation("SourceBranch", fields: [sourceBranchId], references: [id])
  sourceWarehouseId String
  sourceWarehouse   Warehouse @relation("SourceWarehouse", fields: [sourceWarehouseId], references: [id])

  destinationBranchId    String
  destinationBranch      Branch    @relation("DestinationBranch", fields: [destinationBranchId], references: [id])
  destinationWarehouseId String
  destinationWarehouse   Warehouse @relation("DestinationWarehouse", fields: [destinationWarehouseId], references: [id])

  status       StockTransferStatus @default(DRAFT)
  transferDate DateTime            @default(now())
  approvedAt   DateTime?
  shippedAt    DateTime?
  completedAt  DateTime?
  cancelledAt  DateTime?
  reversedAt   DateTime?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items StockTransferItem[]

  @@unique([organizationId, transferNumber])
  @@index([organizationId])
  @@index([organizationId, transferDate(sort: Desc)])
  @@index([organizationId, status])
  @@map("stock_transfers")
}

enum StockTransferStatus {
  DRAFT
  APPROVED
  IN_TRANSIT
  COMPLETED
  CANCELLED
  REVERSED
}

model StockTransferItem {
  id              String        @id @default(cuid())
  stockTransferId String
  stockTransfer   StockTransfer @relation(fields: [stockTransferId], references: [id], onDelete: Cascade)
  organizationId  String
  organization    Organization  @relation(fields: [organizationId], references: [id])

  productId   String
  product     Product    @relation(fields: [productId], references: [id])
  warehouseId String?
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])

  quantity Decimal @db.Decimal(10, 4)
  unitCost Decimal @default(0) @db.Decimal(10, 2)
  notes    String?

  createdAt DateTime @default(now())

  lotConsumptions StockLotConsumption[]

  @@index([stockTransferId])
  @@index([productId])
  @@index([organizationId])
  @@map("stock_transfer_items")
}

// ==================== USER WAREHOUSE ACCESS ====================

model UserWarehouseAccess {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  branchId       String
  branch         Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  warehouseId    String
  warehouse      Warehouse    @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  isDefault      Boolean      @default(false)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())

  @@unique([userId, warehouseId])
  @@index([userId])
  @@index([branchId])
  @@index([organizationId])
  @@map("user_warehouse_access")
}

// ==================== USER CASH/BANK ACCOUNT ACCESS ====================

model UserCashBankAccess {
  id                String          @id @default(cuid())
  userId            String
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  cashBankAccountId String
  cashBankAccount   CashBankAccount @relation(fields: [cashBankAccountId], references: [id], onDelete: Cascade)
  isDefault         Boolean         @default(false)
  organizationId    String
  organization      Organization    @relation(fields: [organizationId], references: [id])
  createdAt         DateTime        @default(now())

  @@unique([userId, cashBankAccountId])
  @@index([userId])
  @@index([cashBankAccountId])
  @@index([organizationId])
  @@map("user_cash_bank_access")
}

// ==================== MOBILE DEVICE TRACKING ====================

enum DeviceStatus {
  IN_STOCK
  RESERVED
  SOLD
  IN_REPAIR
  RMA
}

enum ConditionGrade {
  NEW
  OPEN_BOX
  GRADE_A
  GRADE_B
  GRADE_C
  REFURBISHED
}

enum NetworkStatus {
  UNLOCKED
  LOCKED
}

model MobileDevice {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  // Identification
  imei1            String
  imei2            String?
  serialNumber     String?
  brand            String
  model            String
  color            String?
  storageCapacity  String?
  ram              String?
  networkStatus    NetworkStatus  @default(UNLOCKED)

  // Inventory & Condition
  currentStatus            DeviceStatus   @default(IN_STOCK)
  conditionGrade           ConditionGrade @default(NEW)
  batteryHealthPercentage  Int?
  includedAccessories      Json?

  // Product link
  productId String?
  product   Product? @relation(fields: [productId], references: [id])

  // Sourcing & Cost
  supplierId        String
  supplier          Supplier         @relation(fields: [supplierId], references: [id])
  purchaseInvoiceId String?
  purchaseInvoice   PurchaseInvoice? @relation(fields: [purchaseInvoiceId], references: [id])
  openingStockId    String?
  openingStock      OpeningStock?    @relation(fields: [openingStockId], references: [id])
  inwardDate        DateTime         @default(now())
  costPrice         Decimal          @db.Decimal(10, 2)
  mrp               Decimal          @default(0) @db.Decimal(10, 2)
  landedCost        Decimal          @default(0) @db.Decimal(10, 2)
  sellingPrice      Decimal          @default(0) @db.Decimal(10, 2)

  // Sale Details
  customerId     String?
  customer       Customer? @relation(fields: [customerId], references: [id])
  salesInvoiceId String?
  salesInvoice   Invoice?  @relation(fields: [salesInvoiceId], references: [id])
  outwardDate    DateTime?
  soldPrice      Decimal?  @db.Decimal(10, 2)
  salespersonId  String?
  salesperson    User?     @relation("SoldDevices", fields: [salespersonId], references: [id])

  // Warranty
  supplierWarrantyExpiry  DateTime?
  customerWarrantyExpiry  DateTime?

  notes      String?
  photoUrls  String[]
  createdAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, imei1])
  @@index([organizationId])
  @@index([organizationId, imei2])
  @@index([organizationId, currentStatus])
  @@index([organizationId, supplierId])
  @@index([organizationId, salesInvoiceId])
  @@index([productId])
  @@index([customerId])
  @@index([purchaseInvoiceId])
  @@map("mobile_devices")
}

// ==================== JEWELLERY MODULE ====================

enum MetalType {
  GOLD
  SILVER
  PLATINUM
}

enum GoldPurity {
  K24
  K22
  K21
  K18
  K14
  K9
}

enum MakingChargeType {
  PER_GRAM
  PERCENTAGE
  FIXED
}

enum JewelleryItemStatus {
  IN_STOCK
  SOLD
  IN_REPAIR
  ON_APPROVAL
  MELTED
  IN_DISPLAY
  CONSIGNMENT
}

enum StoneType {
  DIAMOND
  RUBY
  EMERALD
  SAPPHIRE
  PEARL
  ZIRCON
  OTHER
}

enum KarigarTransactionType {
  ISSUE
  RETURN
  WASTAGE
  SCRAP
}

enum PurityTestMethod {
  XRF
  FIRE_ASSAY
  TOUCHSTONE
  OTHER
}

enum RepairStatus {
  RECEIVED
  IN_PROGRESS
  READY
  DELIVERED
  CANCELLED
}

enum SchemeStatus {
  ACTIVE
  COMPLETED
  WITHDRAWN
  DEFAULTED
}

model GoldRate {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  date       DateTime
  metalType  MetalType    @default(GOLD)
  purity     GoldPurity
  buyRate    Decimal      @db.Decimal(12, 2)
  sellRate   Decimal      @db.Decimal(12, 2)
  rateLocked Boolean      @default(false)

  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@unique([organizationId, date, purity, metalType])
  @@index([organizationId])
  @@index([organizationId, date(sort: Desc)])
  @@map("gold_rates")
}

model JewelleryCategory {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  name        String
  arabicName  String?
  slug        String
  metalType   MetalType    @default(GOLD)
  description String?
  sortOrder   Int          @default(0)
  isActive    Boolean      @default(true)

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  items       JewelleryItem[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@map("jewellery_categories")
}

model JewelleryItem {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  // Identification
  tagNumber      String
  rfidTag        String?
  categoryId     String?
  category       JewelleryCategory? @relation(fields: [categoryId], references: [id])

  // Metal properties
  metalType      MetalType    @default(GOLD)
  purity         GoldPurity   @default(K22)
  grossWeight    Decimal      @db.Decimal(10, 3)
  stoneWeight    Decimal      @default(0) @db.Decimal(10, 3)
  netWeight      Decimal      @db.Decimal(10, 3)   // auto: grossWeight - stoneWeight
  fineWeight     Decimal      @db.Decimal(10, 3)   // auto: netWeight * purity/24

  // Making charges
  makingChargeType  MakingChargeType @default(PER_GRAM)
  makingChargeValue Decimal      @default(0) @db.Decimal(12, 2)

  // Wastage
  wastagePercent    Decimal      @default(0) @db.Decimal(5, 2)
  wastageWeight     Decimal      @default(0) @db.Decimal(10, 3)

  // Hallmarking (India)
  huidNumber        String?
  hallmarkNumber    String?

  // SASO (Saudi)
  sasoMark          String?
  sasoAssayerCode   String?
  sasoYear          String?

  // Status & tracking
  status            JewelleryItemStatus @default(IN_STOCK)
  isConsignment     Boolean      @default(false)
  consignmentSupplierId   String?
  consignmentReturnDeadline DateTime?

  // Cost
  costPrice            Decimal   @default(0) @db.Decimal(15, 2)
  goldRateAtPurchase   Decimal   @default(0) @db.Decimal(12, 2)
  stoneValue           Decimal   @default(0) @db.Decimal(15, 2)

  // Relations to existing models
  productId     String?  @unique
  product       Product? @relation(fields: [productId], references: [id])
  supplierId    String?
  supplier      Supplier? @relation(fields: [supplierId], references: [id])
  karigarId     String?
  karigar       Karigar?  @relation(fields: [karigarId], references: [id])

  branchId      String?
  warehouseId   String?

  photoUrls     String[]
  notes         String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  stoneDetails       StoneDetail[]
  karigarTransactions KarigarTransaction[]

  // Reverse relations for transaction items
  invoiceItems          InvoiceItem[]          @relation("InvoiceJewelleryItems")
  quotationItems        QuotationItem[]        @relation("QuotationJewelleryItems")
  purchaseInvoiceItems  PurchaseInvoiceItem[]  @relation("PurchaseJewelleryItems")
  creditNoteItems       CreditNoteItem[]       @relation("CreditNoteJewelleryItems")
  debitNoteItems        DebitNoteItem[]         @relation("DebitNoteJewelleryItems")
  metalLedgerEntries    MetalLedgerEntry[]

  @@unique([organizationId, tagNumber])
  @@unique([organizationId, huidNumber])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, categoryId])
  @@index([organizationId, purity])
  @@index([organizationId, metalType])
  @@index([productId])
  @@index([supplierId])
  @@index([karigarId])
  @@map("jewellery_items")
}

model StoneDetail {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  jewelleryItemId String
  jewelleryItem   JewelleryItem @relation(fields: [jewelleryItemId], references: [id], onDelete: Cascade)

  stoneType           StoneType    @default(DIAMOND)
  carat               Decimal      @default(0) @db.Decimal(8, 3)
  cut                 String?
  color               String?
  clarity             String?
  weight              Decimal      @default(0) @db.Decimal(8, 3)  // in carats (1ct = 0.2g)
  value               Decimal      @default(0) @db.Decimal(15, 2)
  certificationNumber String?
  certBody            String?      // GIA, IGI, etc.
  serialNumber        String?      // for stones > 0.5ct
  isLot               Boolean      @default(false)
  lotCount            Int?

  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  @@index([jewelleryItemId])
  @@index([organizationId])
  @@map("stone_details")
}

model Karigar {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  name                    String
  phone                   String
  specialization          String?
  address                 String?
  goldIssuedWeight        Decimal  @default(0) @db.Decimal(12, 3)
  goldReturnedWeight      Decimal  @default(0) @db.Decimal(12, 3)
  scrapReturnedWeight     Decimal  @default(0) @db.Decimal(12, 3)
  wastageAllowancePercent Decimal  @default(3.00) @db.Decimal(5, 2)
  isActive                Boolean  @default(true)

  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  transactions            KarigarTransaction[]
  jewelleryItems          JewelleryItem[]
  repairs                 JewelleryRepair[]
  metalLedgerEntries      MetalLedgerEntry[] @relation("karigarMetalLedger")

  @@unique([organizationId, phone])
  @@index([organizationId])
  @@map("karigars")
}

model KarigarTransaction {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  karigarId       String
  karigar         Karigar    @relation(fields: [karigarId], references: [id])
  type            KarigarTransactionType
  weight          Decimal    @db.Decimal(10, 3)
  purity          GoldPurity @default(K22)
  fineWeight      Decimal    @db.Decimal(10, 3)  // auto: weight * purity/24
  jewelleryItemId String?
  jewelleryItem   JewelleryItem? @relation(fields: [jewelleryItemId], references: [id])
  date            DateTime   @default(now())
  notes           String?

  createdAt       DateTime   @default(now())

  @@index([karigarId])
  @@index([organizationId])
  @@index([organizationId, date(sort: Desc)])
  @@map("karigar_transactions")
}

model OldGoldPurchase {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  customerId          String?
  customer            Customer? @relation(fields: [customerId], references: [id])
  customerName        String?   // for walk-in

  weight              Decimal   @db.Decimal(10, 3)
  testedPurity        GoldPurity @default(K22)
  purityPercentage    Decimal   @db.Decimal(5, 2)
  testReadings        Json?     // array of 3 XRF readings
  testMethod          PurityTestMethod @default(XRF)
  meltingLossPercent  Decimal   @default(0) @db.Decimal(5, 2)
  rate                Decimal   @db.Decimal(12, 2)
  totalValue          Decimal   @db.Decimal(15, 2)

  adjustedAgainstInvoiceId String?
  adjustedAgainstInvoice   Invoice? @relation(fields: [adjustedAgainstInvoiceId], references: [id])

  panNumber           String?
  notes               String?

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([organizationId])
  @@index([customerId])
  @@index([organizationId, createdAt(sort: Desc)])
  @@map("old_gold_purchases")
}

model JewelleryRepair {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  repairNumber        String
  customerId          String
  customer            Customer @relation(fields: [customerId], references: [id])
  itemDescription     String
  repairType          String?

  estimatedWeight     Decimal?  @db.Decimal(10, 3)
  materialUsedWeight  Decimal?  @db.Decimal(10, 3)
  materialPurity      GoldPurity?

  karigarId           String?
  karigar             Karigar?  @relation(fields: [karigarId], references: [id])

  status              RepairStatus @default(RECEIVED)
  estimatedCost       Decimal?  @db.Decimal(15, 2)
  actualCost          Decimal?  @db.Decimal(15, 2)

  receivedDate        DateTime  @default(now())
  completedDate       DateTime?
  deliveredDate       DateTime?

  photoUrls           String[]
  notes               String?

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([organizationId, repairNumber])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([customerId])
  @@index([karigarId])
  @@map("jewellery_repairs")
}

model CustomerScheme {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  schemeName      String
  customerId      String
  customer        Customer @relation(fields: [customerId], references: [id])
  monthlyAmount   Decimal  @db.Decimal(12, 2)
  durationMonths  Int
  bonusMonths     Int      @default(1)
  startDate       DateTime
  endDate         DateTime   // MUST be within 365 days of start
  status          SchemeStatus @default(ACTIVE)
  totalPaid       Decimal  @default(0) @db.Decimal(12, 2)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  payments        SchemePayment[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([customerId])
  @@map("customer_schemes")
}

model SchemePayment {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  schemeId        String
  scheme          CustomerScheme @relation(fields: [schemeId], references: [id], onDelete: Cascade)
  amount          Decimal  @db.Decimal(12, 2)
  paymentDate     DateTime @default(now())
  paymentMethod   PaymentMethod @default(CASH)
  monthNumber     Int
  reference       String?
  notes           String?

  createdAt       DateTime @default(now())

  @@index([schemeId])
  @@index([organizationId])
  @@map("scheme_payments")
}

enum MetalDirection {
  INFLOW
  OUTFLOW
}

model MetalLedgerEntry {
  id              String         @id @default(cuid())
  organizationId  String
  organization    Organization   @relation(fields: [organizationId], references: [id])

  date            DateTime
  metalType       MetalType      @default(GOLD)
  purity          GoldPurity
  grossWeight     Decimal        @db.Decimal(10, 3)
  fineWeight      Decimal        @db.Decimal(10, 3)
  direction       MetalDirection
  description     String

  // Source tracking (polymorphic, like JournalEntry)
  sourceType      String   // PURCHASE, SALE, KARIGAR_ISSUE, KARIGAR_RETURN, OLD_GOLD_IN, CREDIT_NOTE_RETURN, WASTAGE, SCRAP, PURCHASE_RETURN, ADJUSTMENT
  sourceId        String

  // Optional FK references for querying
  jewelleryItemId     String?
  jewelleryItem       JewelleryItem? @relation(fields: [jewelleryItemId], references: [id])
  karigarId           String?
  karigar             Karigar?       @relation("karigarMetalLedger", fields: [karigarId], references: [id])
  customerId          String?
  customer            Customer?      @relation("customerMetalLedger", fields: [customerId], references: [id])
  supplierId          String?
  supplier            Supplier?      @relation("supplierMetalLedger", fields: [supplierId], references: [id])
  invoiceId           String?
  purchaseInvoiceId   String?
  oldGoldPurchaseId   String?

  createdAt       DateTime @default(now())

  @@index([organizationId])
  @@index([organizationId, date(sort: Desc)])
  @@index([organizationId, sourceType])
  @@index([karigarId])
  @@index([jewelleryItemId])
  @@map("metal_ledger_entries")
}

// ==================== RESTAURANT MODULE ====================

enum RestaurantTableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  CLEANING
}

enum KOTStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum KOTType {
  STANDARD
  FOLLOWUP
  VOID
}

enum RestaurantOrderType {
  DINE_IN
  TAKEAWAY
}

enum RestaurantPOSOrderStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

model RestaurantFloor {
  id              String             @id @default(cuid())
  organizationId  String
  organization    Organization       @relation(fields: [organizationId], references: [id])
  name            String
  sortOrder       Int                @default(0)
  isActive        Boolean            @default(true)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  tables          RestaurantTable[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("restaurant_floors")
}

model RestaurantTable {
  id              String                @id @default(cuid())
  organizationId  String
  organization    Organization          @relation(fields: [organizationId], references: [id])
  number          Int
  name            String
  capacity        Int                   @default(4)
  floor           String?
  section         String?
  status          RestaurantTableStatus @default(AVAILABLE)
  isActive        Boolean               @default(true)
  sortOrder       Int                   @default(0)
  guestCount      Int?
  currentOrderId  String?
  color           String?
  floorId         String?
  restaurantFloor RestaurantFloor?      @relation(fields: [floorId], references: [id])
  shape           String                @default("square")
  posX            Float                 @default(0)
  posY            Float                 @default(0)
  width           Float                 @default(80)
  height          Float                 @default(80)
  rotation        Float                 @default(0)
  cornerRounding  Float                 @default(0)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  kotOrders             KOTOrder[]
  restaurantPOSOrders   RestaurantPOSOrder[]

  @@unique([organizationId, number])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([floorId])
  @@map("restaurant_tables")
}

model KOTOrder {
  id                  String              @id @default(cuid())
  kotNumber           String
  organizationId      String
  organization        Organization        @relation(fields: [organizationId], references: [id])
  tableId             String?
  table               RestaurantTable?    @relation(fields: [tableId], references: [id])
  posSessionId        String?
  posSession          POSSession?         @relation(fields: [posSessionId], references: [id])
  kotType             KOTType             @default(STANDARD)
  orderType           RestaurantOrderType @default(DINE_IN)
  status              KOTStatus           @default(PENDING)
  serverName          String?
  specialInstructions String?             @db.Text
  guestCount          Int?
  createdById         String?
  createdBy           User?               @relation(fields: [createdById], references: [id])
  restaurantPOSOrderId String?
  restaurantPOSOrder   RestaurantPOSOrder? @relation(fields: [restaurantPOSOrderId], references: [id])
  printedAt           DateTime?
  completedAt         DateTime?
  cancelledAt         DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  items               KOTOrderItem[]

  @@unique([organizationId, kotNumber])
  @@index([organizationId])
  @@index([organizationId, createdAt(sort: Desc)])
  @@index([tableId])
  @@index([posSessionId])
  @@index([restaurantPOSOrderId])
  @@map("kot_orders")
}

model KOTOrderItem {
  id           String    @id @default(cuid())
  kotOrderId   String
  kotOrder     KOTOrder  @relation(fields: [kotOrderId], references: [id], onDelete: Cascade)
  productId    String?
  product      Product?  @relation(fields: [productId], references: [id])
  name         String
  nameAr       String?
  variantName  String?
  quantity     Decimal   @db.Decimal(10, 4)
  modifiers    Json?
  notes        String?
  isNew        Boolean   @default(true)
  createdAt    DateTime  @default(now())

  @@index([kotOrderId])
  @@map("kot_order_items")
}

// ==================== RESTAURANT POS ORDERS ====================

model RestaurantPOSOrder {
  id              String                    @id @default(cuid())
  organizationId  String
  organization    Organization              @relation(fields: [organizationId], references: [id])
  tableId         String?
  table           RestaurantTable?          @relation(fields: [tableId], references: [id])
  posSessionId    String?
  posSession      POSSession?               @relation(fields: [posSessionId], references: [id])
  orderType       RestaurantOrderType       @default(DINE_IN)
  orderName       String?
  status          RestaurantPOSOrderStatus  @default(ACTIVE)
  customerId      String?
  customer        Customer?                 @relation(fields: [customerId], references: [id])
  guestCount      Int?
  serverName      String?
  customerNote    String?
  createdById     String?
  createdBy       User?                     @relation("RestaurantPOSOrderCreatedBy", fields: [createdById], references: [id])
  completedAt     DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  lines           RestaurantPOSOrderLine[]
  kotOrders       KOTOrder[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([tableId])
  @@index([posSessionId])
  @@map("restaurant_pos_orders")
}

model RestaurantPOSOrderLine {
  id          String              @id @default(cuid())
  orderId     String
  order       RestaurantPOSOrder  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product?            @relation(fields: [productId], references: [id])
  name        String
  variantId   String?
  variantName String?
  quantity    Decimal             @db.Decimal(10, 4)
  unitPrice   Decimal             @db.Decimal(12, 2)
  discount    Decimal             @default(0) @db.Decimal(10, 2)
  gstRate     Decimal             @default(0) @db.Decimal(5, 2)
  hsnCode     String?
  course      Int                 @default(1)
  sentQty     Decimal             @default(0) @db.Decimal(10, 4)
  notes       String?
  noteChips   Json?
  modifiers   Json?
  categoryId  String?
  sortOrder   Int                 @default(0)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([orderId])
  @@map("restaurant_pos_order_lines")
}

// ==================== COMMENTS ====================

model CustomerComment {
  id             String       @id @default(cuid())
  customerId     String
  customer       Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation("CustomerComments", fields: [userId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  content        String       @db.Text
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([customerId])
  @@index([organizationId])
  @@map("customer_comments")
}

model SupplierComment {
  id             String       @id @default(cuid())
  supplierId     String
  supplier       Supplier     @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation("SupplierComments", fields: [userId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  content        String       @db.Text
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([supplierId])
  @@index([organizationId])
  @@map("supplier_comments")
}

// ==================== PRICE LISTS ====================

model PriceList {
  id                     String       @id @default(cuid())
  name                   String
  description            String?
  isActive               Boolean      @default(true)
  defaultDiscountPercent Decimal      @default(0) @db.Decimal(5, 2)
  organizationId         String
  organization           Organization @relation(fields: [organizationId], references: [id])
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  items                  PriceListItem[]
  assignments            PriceListAssignment[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([organizationId, isActive])
  @@map("price_lists")
}

model PriceListItem {
  id            String    @id @default(cuid())
  priceListId   String
  priceList     PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  productId     String
  product       Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  unitId        String?
  unit          Unit?     @relation(fields: [unitId], references: [id])
  overrideType  String    @default("FIXED")  // "FIXED" or "PERCENTAGE"
  fixedPrice    Decimal?  @db.Decimal(10, 2)
  percentOffset Decimal?  @db.Decimal(5, 2)   // negative = discount, positive = markup
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([priceListId, productId, unitId])
  @@index([priceListId])
  @@index([productId])
  @@map("price_list_items")
}

model PriceListAssignment {
  id             String       @id @default(cuid())
  priceListId    String
  priceList      PriceList    @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  userId         String?      @unique
  user           User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  customerId     String?      @unique
  customer       Customer?    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  assignedAt     DateTime     @default(now())

  @@index([priceListId])
  @@index([organizationId])
  @@map("price_list_assignments")
}

// ==================== USER ORGANIZATION MEMBERSHIP ====================

model UserOrganization {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation("OrgMemberships", fields: [organizationId], references: [id], onDelete: Cascade)
  role           String       @default("user")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
  @@map("user_organizations")
}

// ==================== ATTACHMENTS ====================

model Attachment {
  id             String   @id @default(cuid())
  organizationId String
  documentType   String   // "invoice", "purchase_invoice", "quotation", "credit_note", "debit_note", "expense", "journal_entry", "inventory_adjustment", "stock_transfer"
  documentId     String
  fileName       String
  fileKey        String   // R2 object key
  fileSize       Int      // bytes
  fileType       String   // MIME type
  uploadedById   String
  createdAt      DateTime @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  uploadedBy     User         @relation(fields: [uploadedById], references: [id])

  @@index([organizationId, documentType, documentId])
  @@index([organizationId])
  @@map("attachments")
}
