// BizArch ERP - Database Schema
// Prisma 7.x with PostgreSQL on Neon

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==================== ENUMS ====================

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  SUSPENDED
}

// ==================== ORGANIZATIONS ====================

model Organization {
  id                 String   @id @default(cuid())
  name               String
  slug               String   @unique
  gstEnabled         Boolean  @default(false)
  eInvoicingEnabled  Boolean  @default(false)
  multiUnitEnabled   Boolean  @default(false)
  multiBranchEnabled         Boolean  @default(false)
  isScannerEnabled             Boolean  @default(false)
  isMobileShopModuleEnabled  Boolean  @default(false)
  isWeighMachineEnabled        Boolean  @default(false)

  // Jewellery Module
  isJewelleryModuleEnabled     Boolean  @default(false)
  jewelleryHuidMandatory       Boolean  @default(true)
  jewellerySasoMandatory       Boolean  @default(true)
  jewelleryConsignmentEnabled  Boolean  @default(false)
  jewellerySchemesEnabled      Boolean  @default(true)
  jewelleryOldGoldEnabled      Boolean  @default(true)
  jewelleryRepairsEnabled      Boolean  @default(true)
  jewelleryKarigarsEnabled     Boolean  @default(true)

  // Jewellery Tax & Compliance
  jewelleryGoldTaxRate              Decimal  @default(3.00) @db.Decimal(5, 2)
  jewelleryMakingChargeTaxRate      Decimal  @default(5.00) @db.Decimal(5, 2)
  jewelleryStoneTaxRate             Decimal  @default(3.00) @db.Decimal(5, 2)
  jewelleryInvestmentGoldTaxRate    Decimal  @default(3.00) @db.Decimal(5, 2)
  jewelleryPanRequired              Boolean  @default(true)
  jewelleryPanThreshold             Decimal  @default(200000) @db.Decimal(15, 2)
  jewelleryCashLimitEnabled         Boolean  @default(true)
  jewelleryCashLimitAmount          Decimal  @default(200000) @db.Decimal(15, 2)
  jewelleryTcsEnabled               Boolean  @default(false)
  jewelleryTcsRate                  Decimal  @default(1.00) @db.Decimal(5, 2)
  jewelleryTcsThreshold             Decimal  @default(500000) @db.Decimal(15, 2)

  // Jewellery Business Rules
  jewelleryDefaultWastagePercent    Decimal  @default(5.00) @db.Decimal(5, 2)
  jewelleryKarigarWastageTolerance  Decimal  @default(3.00) @db.Decimal(5, 2)
  jewelleryWeightTolerance          Decimal  @default(0.050) @db.Decimal(5, 3)
  jewelleryBuyRateSpread            Decimal  @default(5.00) @db.Decimal(5, 2)
  jewelleryAutoDerivePurities       Boolean  @default(true)
  jewelleryAgingAlertDays           Int      @default(180)
  jewelleryReconciliationTolerance  Decimal  @default(1.00) @db.Decimal(5, 2)
  jewelleryDefaultMakingChargeType  MakingChargeType @default(PER_GRAM)

  // Jewellery Scheme Settings (India)
  jewellerySchemeMaxDuration        Int      @default(11)
  jewellerySchemeBonusMonths        Int      @default(1)
  jewellerySchemeEnforce365Days     Boolean  @default(true)
  jewellerySchemeRedemptionDiscount Decimal  @default(0) @db.Decimal(5, 2)

  // Jewellery Theme & Branding
  jewelleryThemeEnabled             Boolean  @default(true)
  jewelleryThemeColor               String?  @default("#b8860b")
  jewelleryThemePreset              String?  @default("gold")

  // Jewellery Enabled Purities & Metals
  jewelleryEnabledPurities          String[] @default(["K24", "K22", "K21", "K18", "K14", "K9"])
  jewelleryEnabledMetals            String[] @default(["GOLD", "SILVER", "PLATINUM"])

  // Price List Module
  isPriceListEnabled                Boolean  @default(false)

  // Restaurant Module
  isRestaurantModuleEnabled         Boolean  @default(false)
  restaurantTablesEnabled           Boolean  @default(true)
  restaurantKotPrintingEnabled      Boolean  @default(true)

  // Restaurant Theme & Branding
  restaurantThemeEnabled            Boolean  @default(true)
  restaurantThemeColor              String?  @default("#c0392b")
  restaurantThemePreset             String?  @default("bistro")

  weighMachineBarcodePrefix    String?  @default("77")
  weighMachineProductCodeLen   Int?     @default(5)
  weighMachineWeightDigits     Int?     @default(5)
  weighMachineDecimalPlaces    Int?     @default(3)
  edition            String   @default("INDIA")  // "INDIA" or "SAUDI"
  gstin              String?
  gstStateCode       String?

  // Saudi e-Invoice Phase 1
  saudiEInvoiceEnabled  Boolean  @default(false)
  vatNumber             String?   // 15-digit TRN (starts with 3)
  commercialRegNumber   String?   // Commercial Registration Number
  arabicName            String?   // Arabic company name
  arabicAddress         String?   // Arabic address
  arabicCity            String?   // Arabic city

  // Company Details (consolidated from Settings key-value table)
  address               String?
  city                  String?
  state                 String?
  zipCode               String?
  country               String?
  phone                 String?
  email                 String?
  bankName              String?
  bankAccountNumber     String?
  bankIfscCode          String?
  bankBranch            String?
  roundOffMode          String    @default("NONE")

  // PDF Customization
  pdfHeaderImageUrl     String?  // Edge-to-edge header image URL for A4 invoices
  pdfFooterImageUrl     String?  // Edge-to-edge footer image URL for A4 invoices
  brandColor            String?  // Hex color for PDF branding, e.g. "#2a3b38"
  invoiceLogoHeight     Int?     @default(60)   // Logo height (px) on invoice PDF
  logoUrl               String?  // Company logo URL for logo-based templates and receipts

  // POS Receipt Customization
  posReceiptLogoUrl     String?  // Separate logo URL for POS receipts (falls back to logoUrl)
  posReceiptLogoHeight  Int?     @default(80)   // Logo height (px) on POS receipt

  // POS Employee PIN
  posEmployeePinRequired     Boolean  @default(false)

  // POS Accounting
  posAccountingMode          String   @default("DIRECT")  // "DIRECT" or "CLEARING_ACCOUNT"
  posDefaultCashAccountId    String?
  posDefaultCashAccount      CashBankAccount? @relation("OrgDefaultCashAccount", fields: [posDefaultCashAccountId], references: [id])
  posDefaultBankAccountId    String?
  posDefaultBankAccount      CashBankAccount? @relation("OrgDefaultBankAccount", fields: [posDefaultBankAccountId], references: [id])

  // Tax-Inclusive Pricing
  isTaxInclusivePrice   Boolean  @default(false)

  // Localization
  language              String   @default("en")  // "en" or "ar" — org-wide UI language
  currency              String   @default("INR") // "INR" or "SAR" — org-wide currency

  // Subscription Management
  subscriptionStatus    SubscriptionStatus @default(TRIAL)
  subscriptionStartDate DateTime?
  subscriptionEndDate   DateTime?
  subscriptionNotes     String?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  users                      User[]
  customers                  Customer[]
  customerAssignments        CustomerAssignment[]
  customerTransactions       CustomerTransaction[]
  suppliers                  Supplier[]
  supplierTransactions       SupplierTransaction[]
  products                   Product[]
  units                      Unit[]
  invoices                   Invoice[]
  invoiceItems               InvoiceItem[]
  quotations                 Quotation[]
  quotationItems             QuotationItem[]
  purchaseInvoices           PurchaseInvoice[]
  purchaseInvoiceItems       PurchaseInvoiceItem[]
  creditNotes                CreditNote[]
  creditNoteItems            CreditNoteItem[]
  debitNotes                 DebitNote[]
  debitNoteItems             DebitNoteItem[]
  debitNoteLotConsumptions   DebitNoteLotConsumption[]
  payments                   Payment[]
  paymentAllocations         PaymentAllocation[]
  supplierPayments           SupplierPayment[]
  supplierPaymentAllocations SupplierPaymentAllocation[]
  stockLots                  StockLot[]
  stockLotConsumptions       StockLotConsumption[]
  openingStocks              OpeningStock[]
  costAuditLogs              CostAuditLog[]
  settings                   Setting[]
  accounts                   Account[]
  cashBankAccounts           CashBankAccount[]
  cashBankTransactions       CashBankTransaction[]
  expenses                   Expense[]
  expenseItems               ExpenseItem[]
  journalEntries             JournalEntry[]
  journalEntryLines          JournalEntryLine[]
  productCategories          ProductCategory[]
  employees                  Employee[]
  posSessions                POSSession[]
  posHeldOrders              POSHeldOrder[]
  posRegisterConfigs         POSRegisterConfig[]
  unitConversions            UnitConversion[]
  branches                   Branch[]
  warehouses                 Warehouse[]
  stockTransfers             StockTransfer[]
  stockTransferItems         StockTransferItem[]
  userWarehouseAccess        UserWarehouseAccess[]
  userCashBankAccess         UserCashBankAccess[]
  mobileDevices              MobileDevice[]
  productBundleItems         ProductBundleItem[]

  // Jewellery Module Relations
  goldRates                  GoldRate[]
  jewelleryCategories        JewelleryCategory[]
  jewelleryItems             JewelleryItem[]
  stoneDetails               StoneDetail[]
  karigars                   Karigar[]
  karigarTransactions        KarigarTransaction[]
  oldGoldPurchases           OldGoldPurchase[]
  jewelleryRepairs           JewelleryRepair[]
  customerSchemes            CustomerScheme[]
  schemePayments             SchemePayment[]
  metalLedgerEntries         MetalLedgerEntry[]
  subscriptionLogs           SubscriptionLog[]

  // Inventory Adjustment Relations
  inventoryAdjustments       InventoryAdjustment[]
  inventoryAdjustmentItems   InventoryAdjustmentItem[]

  // Restaurant Module Relations
  restaurantFloors           RestaurantFloor[]
  restaurantTables           RestaurantTable[]
  restaurantPOSOrders        RestaurantPOSOrder[]
  kotOrders                  KOTOrder[]

  // Comment Relations
  customerComments           CustomerComment[]
  supplierComments           SupplierComment[]

  // Price List Relations
  priceLists                 PriceList[]
  priceListAssignments       PriceListAssignment[]

  // Product Unit Conversion Relations
  productUnitConversions     ProductUnitConversion[]
  productVariants            ProductVariant[]

  // Multi-org membership
  memberships                UserOrganization[] @relation("OrgMemberships")

  // Attachments
  attachments                Attachment[]

  @@map("organizations")
}

// ==================== SUBSCRIPTION ====================

model SubscriptionLog {
  id              String              @id @default(cuid())
  organizationId  String
  organization    Organization        @relation(fields: [organizationId], references: [id])
  previousStatus  SubscriptionStatus?
  newStatus       SubscriptionStatus
  previousEndDate DateTime?
  newEndDate      DateTime?
  changedBy       String              // superadmin user id
  note            String?
  createdAt       DateTime            @default(now())

  @@index([organizationId])
  @@map("subscription_logs")
}

// ==================== AUTH ====================

model User {
  id             String        @id @default(cuid())
  email          String        @unique
  password       String
  name           String
  role           String        @default("user") // superadmin, admin, user
  language       String?       // "en" or "ar" — per-user override; null = use org default
  formDefaults   String?       // JSON: per-user form default overrides (branch, warehouse)
  landingPage    String?       // Per-user landing page override (e.g., "/pos", "/invoices")
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  customerAssignments CustomerAssignment[]
  invoices            Invoice[]
  creditNotes         CreditNote[]
  posSessionsOpened   POSSession[]   @relation("OpenedSessions")
  posSessionsClosed   POSSession[]   @relation("ClosedSessions")
  warehouseAccess     UserWarehouseAccess[]
  soldDevices         MobileDevice[]     @relation("SoldDevices")
  kotOrders           KOTOrder[]
  restaurantPOSOrders RestaurantPOSOrder[] @relation("RestaurantPOSOrderCreatedBy")
  settings            Setting[]          @relation("UserSettings")
  customerComments    CustomerComment[]  @relation("CustomerComments")
  supplierComments    SupplierComment[]  @relation("SupplierComments")
  priceListAssignment PriceListAssignment?
  organizations       UserOrganization[]
  cashBankAccess      UserCashBankAccess[]
  cashBankTransactions CashBankTransaction[] @relation("CashBankTransactionCreator")
  attachments          Attachment[]

  @@index([organizationId])
  @@index([organizationId, name])
  @@map("users")
}

// ==================== EMPLOYEES ====================

model Employee {
  id             String       @id @default(cuid())
  name           String
  pinCode        String?
  isActive       Boolean      @default(true)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  posSessions    POSSession[]

  @@unique([organizationId, pinCode])
  @@index([organizationId])
  @@map("employees")
}

// ==================== UNITS ====================

model Unit {
  id             String       @id @default(cuid())
  code           String
  name           String
  isActive       Boolean      @default(true)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  products             Product[]
  invoiceItems         InvoiceItem[]
  purchaseInvoiceItems PurchaseInvoiceItem[]
  quotationItems       QuotationItem[]
  creditNoteItems      CreditNoteItem[]
  debitNoteItems       DebitNoteItem[]
  conversionsFrom      UnitConversion[]      @relation("FromUnit")
  conversionsTo        UnitConversion[]      @relation("ToUnit")
  productUnitConversions ProductUnitConversion[]
  priceListItems         PriceListItem[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@map("units")
}

// ==================== PRODUCTS ====================

model Product {
  id             String           @id @default(cuid())
  name           String
  arabicName     String?          // Arabic product name for Saudi invoices
  description    String?
  imageUrl       String?
  price          Decimal          @db.Decimal(10, 2)
  cost           Decimal          @default(0) @db.Decimal(10, 2)
  unitCode       String?
  unitId         String?
  unit           Unit?            @relation(fields: [unitId], references: [id])
  sku            String?
  barcode        String?
  hsnCode        String?
  gstRate        Decimal          @default(0) @db.Decimal(5, 2)
  isService      Boolean          @default(false)
  isImeiTracked     Boolean          @default(false)
  weighMachineCode  String?          // 5-digit code embedded in weight barcode label
  isBundle          Boolean          @default(false)  // Bundle/Kit product: stock deducted from components
  modifiers         String[]         @default([])     // Predefined modifier options e.g. ["Extra Sugar", "Thin Crust"]
  isActive          Boolean          @default(true)
  organizationId    String
  organization   Organization     @relation(fields: [organizationId], references: [id])
  categoryId     String?
  category       ProductCategory? @relation(fields: [categoryId], references: [id])
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  invoiceItems         InvoiceItem[]
  purchaseInvoiceItems PurchaseInvoiceItem[]
  stockLots            StockLot[]
  openingStocks        OpeningStock[]
  quotationItems       QuotationItem[]
  creditNoteItems      CreditNoteItem[]
  debitNoteItems       DebitNoteItem[]
  costAuditLogs        CostAuditLog[]
  stockTransferItems         StockTransferItem[]
  mobileDevices              MobileDevice[]
  bundleItems                ProductBundleItem[]  @relation("BundleParent")
  bundleParents              ProductBundleItem[]  @relation("BundleComponent")
  inventoryAdjustmentItems   InventoryAdjustmentItem[]

  // Jewellery relation (1:1)
  jewelleryItem        JewelleryItem?

  // Restaurant relations
  kotOrderItems              KOTOrderItem[]
  restaurantPOSOrderLines    RestaurantPOSOrderLine[]

  // Price List relation
  priceListItems       PriceListItem[]

  // Product-level unit conversions
  unitConversions      ProductUnitConversion[]

  // Product variants (e.g. Medium/Large sizes with different prices)
  variants             ProductVariant[]

  @@unique([organizationId, sku])
  @@unique([organizationId, barcode])
  @@unique([organizationId, weighMachineCode])
  @@index([organizationId])
  @@index([organizationId, name])
  @@index([organizationId, categoryId])
  @@map("products")
}

model ProductBundleItem {
  id               String       @id @default(cuid())
  bundleProductId  String
  bundleProduct    Product      @relation("BundleParent", fields: [bundleProductId], references: [id], onDelete: Cascade)
  componentProductId String
  componentProduct   Product    @relation("BundleComponent", fields: [componentProductId], references: [id])
  quantity         Decimal      @db.Decimal(10, 4)  // Qty of component per 1 unit of bundle
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id])
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@unique([bundleProductId, componentProductId])
  @@index([organizationId])
  @@index([bundleProductId])
  @@map("product_bundle_items")
}

model UnitConversion {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  fromUnitId String
  fromUnit   Unit   @relation("FromUnit", fields: [fromUnitId], references: [id])

  toUnitId String
  toUnit   Unit   @relation("ToUnit", fields: [toUnitId], references: [id])

  conversionFactor Decimal @db.Decimal(10, 4)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, fromUnitId, toUnitId])
  @@index([organizationId])
  @@index([fromUnitId])
  @@index([toUnitId])
  @@map("unit_conversions")
}

model ProductUnitConversion {
  id               String       @id @default(cuid())
  productId        String
  product          Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  unitId           String
  unit             Unit         @relation(fields: [unitId], references: [id])
  conversionFactor Decimal      @db.Decimal(10, 4)
  barcode              String?
  price                Decimal?     @db.Decimal(10, 2)
  isDefaultUnit   Boolean      @default(false)
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id])
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@unique([productId, unitId])
  @@index([organizationId])
  @@index([productId])
  @@map("product_unit_conversions")
}

model ProductVariant {
  id             String       @id @default(cuid())
  productId      String
  product        Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  name           String
  price          Decimal      @db.Decimal(10, 2)
  cost           Decimal      @default(0) @db.Decimal(10, 2)
  barcode        String?
  sortOrder      Int          @default(0)
  isActive       Boolean      @default(true)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([productId, name])
  @@index([productId])
  @@index([organizationId])
  @@map("product_variants")
}

// ==================== CUSTOMERS ====================

model Customer {
  id             String       @id @default(cuid())
  name           String
  email          String?
  phone          String?
  address        String?
  city           String?
  state          String?
  zipCode        String?
  country        String?      @default("India")
  gstin          String?
  gstStateCode   String?
  // Saudi fields
  arabicName     String?
  vatNumber      String?      // Customer's VAT TRN (for standard invoices)
  ccNo           String?
  buildingNo     String?
  addNo          String?
  district       String?
  balance        Decimal      @default(0) @db.Decimal(12, 2)
  notes          String?
  isActive       Boolean      @default(true)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  invoices      Invoice[]
  payments      Payment[]
  transactions  CustomerTransaction[]
  quotations    Quotation[]
  assignments   CustomerAssignment[]
  creditNotes   CreditNote[]
  posHeldOrders POSHeldOrder[]
  mobileDevices MobileDevice[]

  comments             CustomerComment[]
  restaurantPOSOrders  RestaurantPOSOrder[]

  // Jewellery relations
  jewelleryRepairs   JewelleryRepair[]
  oldGoldPurchases   OldGoldPurchase[]
  customerSchemes    CustomerScheme[]
  metalLedgerEntries MetalLedgerEntry[] @relation("customerMetalLedger")

  priceListAssignment PriceListAssignment?

  @@index([organizationId])
  @@index([organizationId, name])
  @@map("customers")
}

model CustomerAssignment {
  id             String       @id @default(cuid())
  customerId     String
  userId         String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  assignedAt     DateTime     @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([customerId, userId])
  @@index([organizationId])
  @@map("customer_assignments")
}

// ==================== SUPPLIERS ====================

model Supplier {
  id             String       @id @default(cuid())
  name           String
  email          String?
  phone          String?
  address        String?
  city           String?
  state          String?
  zipCode        String?
  country        String?      @default("India")
  gstin          String?
  gstStateCode   String?
  // Saudi fields
  arabicName     String?
  vatNumber      String?      // Supplier's VAT TRN
  ccNo           String?
  buildingNo     String?
  addNo          String?
  district       String?
  balance        Decimal      @default(0) @db.Decimal(12, 2)
  notes          String?
  isActive       Boolean      @default(true)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  purchaseInvoices PurchaseInvoice[]
  payments         SupplierPayment[]
  transactions     SupplierTransaction[]
  debitNotes       DebitNote[]
  expenses         Expense[]
  mobileDevices    MobileDevice[]

  comments         SupplierComment[]

  // Jewellery relations
  jewelleryItems         JewelleryItem[]
  metalLedgerEntries     MetalLedgerEntry[] @relation("supplierMetalLedger")

  @@index([organizationId])
  @@index([organizationId, name])
  @@map("suppliers")
}

// ==================== INVOICES (SALES) ====================

model Invoice {
  id             String       @id @default(cuid())
  invoiceNumber  String
  customerId     String
  customer       Customer     @relation(fields: [customerId], references: [id])
  createdById    String?
  createdBy      User?        @relation(fields: [createdById], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  issueDate DateTime @default(now())
  dueDate   DateTime

  subtotal   Decimal @db.Decimal(12, 2)
  total      Decimal @db.Decimal(12, 2)
  amountPaid Decimal @default(0) @db.Decimal(12, 2)
  balanceDue Decimal @db.Decimal(12, 2)
  roundOffAmount    Decimal @default(0) @db.Decimal(12, 2)
  applyRoundOff     Boolean @default(false)

  totalCgst     Decimal @default(0) @db.Decimal(12, 2)
  totalSgst     Decimal @default(0) @db.Decimal(12, 2)
  totalIgst     Decimal @default(0) @db.Decimal(12, 2)
  placeOfSupply String?
  isInterState  Boolean @default(false)

  eInvoiceIrn      String?
  eInvoiceAckNo    String?
  eInvoiceAckDate  DateTime?
  eInvoiceSignedQr String?   @db.Text
  eInvoiceStatus   String?

  // Saudi e-Invoice Phase 1
  saudiInvoiceType     String?            // "STANDARD" or "SIMPLIFIED"
  totalVat             Decimal? @db.Decimal(12, 2)
  qrCodeData           String?  @db.Text  // Base64-encoded TLV QR data
  invoiceUuid          String?            // UUID per ZATCA requirement
  invoiceCounterValue  Int?               // Sequential ICV (tamper-resistant)
  previousInvoiceHash  String?            // SHA-256 hash of previous invoice
  invoiceHash          String?            // SHA-256 hash of this invoice

  sentAt DateTime?

  notes String?
  terms String?

  sourceType   InvoiceSourceType @default(MANUAL)
  posSessionId String?
  posSession   POSSession?       @relation(fields: [posSessionId], references: [id])

  branchId    String?
  branch      Branch?    @relation(fields: [branchId], references: [id])
  warehouseId String?
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])

  paymentType String   @default("CASH") // "CASH" or "CREDIT"

  isTaxInclusive Boolean? // null = use org default, true/false = per-voucher override

  idempotencyKey String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items              InvoiceItem[]
  payments           Payment[]
  paymentAllocations PaymentAllocation[]
  quotation          Quotation?
  creditNotes        CreditNote[]
  mobileDevices      MobileDevice[]

  // Jewellery fields
  isJewellerySale    Boolean  @default(false)
  oldGoldDeduction   Decimal  @default(0) @db.Decimal(15, 2)
  oldGoldAdjustments OldGoldPurchase[]

  @@unique([organizationId, invoiceNumber])
  @@unique([organizationId, idempotencyKey])
  @@index([organizationId])
  @@index([organizationId, createdAt(sort: Desc)])
  @@index([organizationId, issueDate(sort: Desc)])
  @@index([organizationId, customerId])
  @@map("invoices")
}

model InvoiceItem {
  id             String       @id @default(cuid())
  invoiceId      String
  invoice        Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  productId String?
  product   Product? @relation(fields: [productId], references: [id])
  unitId    String?
  unit      Unit?    @relation(fields: [unitId], references: [id])
  variantId   String?
  variantName String?

  conversionFactor Decimal @default(1) @db.Decimal(10, 4)

  description String
  quantity    Decimal @db.Decimal(10, 4)
  unitPrice   Decimal @db.Decimal(10, 2)
  discount    Decimal @default(0) @db.Decimal(5, 2)
  total       Decimal @db.Decimal(12, 2)

  hsnCode    String?
