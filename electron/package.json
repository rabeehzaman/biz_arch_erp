{
  "name": "bizarch-erp-desktop",
  "version": "1.2.5",
  "description": "BizArch ERP Desktop App with silent thermal printing",
  "main": "main.js",
  "author": "BizArch <dev@bizarch.com>",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder build",
    "build:win": "electron-builder build --win",
    "build:mac": "electron-builder build --mac",
    "build:publish": "electron-builder build --publish always",
    "build:publish:win": "electron-builder build --win --publish always",
    "build:publish:mac": "electron-builder build --mac --publish always",
    "pack": "electron-builder --dir",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@node-escpos/usb-adapter": "^0.3.1",
    "electron-updater": "^6.8.3",
    "iconv-lite": "^0.6.3",
    "node-thermal-printer": "^4.6.0",
    "pngjs": "^7.0.0",
    "usb": "^2.17.0"
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.bizarch.erp-printer",
    "productName": "BizArch ERP",
    "copyright": "Copyright © 2025 BizArch",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "printer-service.js",
      "winspool-raw.js",
      "loading.html",
      "node_modules/**/*",
      "package.json"
    ],
    "asar": true,
    "npmRebuild": false,
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.business"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "BizArch ERP",
      "runAfterFinish": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "rabeehzaman",
        "repo": "biz_arch_erp",
        "releaseType": "release"
      }
    ]
  }
}